# BTP Smart Pro — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# ─── Supabase ───────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PUBLISHABLE_KEY=

# ─── URLs de l'application ──────────────────────────────────
# URL de l'app en production (utilisée pour les liens de signature, emails, etc.)
VITE_APP_URL=https://votre-domaine.com
VITE_PUBLIC_URL=https://votre-domaine.com
VITE_PRODUCTION_URL=https://votre-domaine.com

# ─── Stripe ─────────────────────────────────────────────────
# Prix Stripe (obtenus depuis le dashboard Stripe > Produits)
VITE_STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_PRICE_ID_MENSUEL=price_xxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_PRICE_ID_ANNUEL=price_xxxxxxxxxxxxxxxxxxxx
# JSON des plans (ex: {"mensuel":"price_xxx","annuel":"price_xxx"})
VITE_STRIPE_PLANS=

# ─── Accès admin ────────────────────────────────────────────
# Email(s) des super-admins de la plateforme
VITE_ADMIN_EMAIL=admin@example.com
# Emails des closers séparés par virgule
VITE_CLOSER_EMAILS=closer1@example.com,closer2@example.com

# ─── Mode démo / développement ──────────────────────────────
# Mettre à "true" pour activer le mode démo (données fictives)
VITE_APP_DEMO=false
VITE_FAKE_DATA=false
# Niveau de logs : "debug" | "info" | "warn" | "error"
VITE_LOG_LEVEL=warn
